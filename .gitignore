# ─── Dependencies ───────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ───────────────────────────────────
/.next/
/out/
/build

# ─── Environment variables (NEVER commit secrets) ───────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ─── Uploads / user-generated content ───────────────────────
/public/uploads/
/uploads/

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ────────────────────────────────────────────────
/coverage
/.nyc_output

# ─── Debug logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ─── OS / Editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.pem
.idea/
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Deployment / hosting ───────────────────────────────────
.vercel
.netlify

# ─── Misc ───────────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
tmp/
temp/
